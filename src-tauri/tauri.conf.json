{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Usticky",
  "version": "0.1.0",
  "identifier": "com.usticky.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "floating",
        "title": "Usticky",
        "width": 300,
        "height": 200,
        "minWidth": 240,
        "minHeight": 160,
        "maxWidth": 420,
        "maxHeight": 2400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": true,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc:; font-src 'self' data:; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Always-on-top floating sticky note",
    "longDescription": "桌面浮窗 + 系统托盘，本地 todo 工具，玻璃质感，零联网",
    "macOS": {
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}
