<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Usticky — macOS Hardened Runtime entitlements
      ==============================================
      从 Musage 继承：Usticky 不联网（todos 存本地 JSON），但保留以下 entitlement
      以满足 Tauri 2 + macos-private-api + WKWebView JIT 的最小集合。

      注意：
      - App **不上沙盒**（PinBottom 模式需要 setLevel，沙盒不允许）
      - 没 Apple Developer ID 也能用此文件 + codesign --sign -（ad-hoc），
        只是 spctl --assess 会报 "rejected"，用户能跑就行
    -->

    <!-- Hardened Runtime 必需: 允许 JIT (WKWebView 内部用) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Hardened Runtime 必需: 允许未签名可执行内存 (WKWebView 内部) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Hardened Runtime 必需: 关掉库签名校验，objc2 + 私有 API 才能 load 系统 framework -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- **2026-07-17 cleanup**：删 network.client entitlement。
         Usticky 产品承诺"不联网"（README line 9 + AGENTS.md line 10），实际
         代码确认零网络请求（CSP 也禁了非 self/ipc 的 connect）。多余
         entitlement 在 Hardened Runtime 下只是攻击面 —— 即便以后接
         Tauri updater，entitlement 加回来即可，不需要"提前留"。 -->
</dict>
</plist>